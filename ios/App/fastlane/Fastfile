# Generic iOS fastlane config for Capacitor apps.
# Run from ios/App/ directory:
#   fastlane status     — show latest TestFlight build number
#   fastlane build      — web + cap sync + archive + export IPA
#   fastlane upload     — upload current IPA to TestFlight (waits for processing)
#   fastlane submit     — attach build to App Store version + submit for review
#   fastlane release    — full pipeline: build + upload + submit
#
# Credentials come from env vars (NEVER hardcode keys in this file):
#   ASC_KEY_ID       App Store Connect API Key ID
#   ASC_ISSUER_ID    App Store Connect Issuer ID
#   ASC_KEY_PATH     Absolute path to AuthKey_*.p8

default_platform(:ios)

def asc_key
  app_store_connect_api_key(
    key_id:       ENV.fetch("ASC_KEY_ID"),
    issuer_id:    ENV.fetch("ASC_ISSUER_ID"),
    key_filepath: File.expand_path(ENV.fetch("ASC_KEY_PATH")),
    in_house:     false
  )
end

platform :ios do
  desc "Show latest TestFlight build number"
  lane :status do
    latest = latest_testflight_build_number(api_key: asc_key)
    UI.success("Latest TestFlight build number: #{latest}")
  end

  desc "Web build + Capacitor sync + Xcode archive + export signed IPA"
  lane :build do
    # Remove any stale archive/export dir BEFORE cap sync — a leftover ios/App/build makes
    # `cap sync ios` fail with a misleading "ios platform has not been added yet".
    sh("rm", "-rf", "build")
    Dir.chdir("../..") do
      sh("npm", "run", "build")
      sh("npx", "cap", "sync", "ios")
    end
    archive_only
  end

  desc "Xcode archive + export signed IPA only (web build + cap sync already done)"
  lane :archive_only do
    sh("rm", "-rf", "build")
    # Manual signing on the App target ONLY. Setting the profile globally (via xcargs)
    # leaks it onto the Pods targets, which don't support provisioning profiles.
    update_code_signing_settings(
      use_automatic_signing: false,
      path:                  "App.xcodeproj",
      team_id:               "9B895DPQKP",
      code_sign_identity:    "Apple Distribution",
      profile_name:          "com.unitedconnect.app AppStore",
      targets:               ["App"],
      bundle_identifier:     "com.unitedconnect.app"
    )
    build_app(
      workspace:        "App.xcworkspace",
      scheme:           "App",
      configuration:    "Release",
      export_method:    "app-store",
      output_directory: "build",
      clean:            true,
      export_options: {
        method:       "app-store",
        signingStyle: "manual",
        provisioningProfiles: {
          "com.unitedconnect.app" => "com.unitedconnect.app AppStore"
        }
      }
    )
  end

  desc "Upload the latest IPA to App Store Connect / TestFlight"
  lane :upload do
    upload_to_testflight(
      api_key:                           asc_key,
      ipa:                               "build/App.ipa",
      skip_submission:                   true,
      skip_waiting_for_build_processing: true
    )
  end

  desc "Submit current processed build for App Store review. Pass version: if auto-detect fails."
  lane :submit do |options|
    version = options[:version] || sh("/usr/libexec/PlistBuddy", "-c", "Print CFBundleShortVersionString", "../App/Info.plist").strip rescue nil
    deliver(
      api_key:            asc_key,
      app_version:        version,
      submit_for_review:  true,
      automatic_release:  true,
      force:              true,
      skip_screenshots:   true,
      skip_metadata:      false,
      precheck_include_in_app_purchases: false,
      submission_information: {
        add_id_info_uses_idfa:                false,
        export_compliance_uses_encryption:    false,
        export_compliance_encryption_updated: false
      }
    )
  end

  desc "Full release: build -> upload -> wait for processing -> submit"
  lane :release do
    build
    upload
    submit
  end
end
